{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run scripts/check-grammars.ts && vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "biome check . && bun run scripts/check-grammars.ts && bun run scripts/check-examples.ts",
    "check:examples": "bun run scripts/check-examples.ts",
    "check:links": "bun run scripts/check-links.ts",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.10.1",
    "shiki": "^4.3.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}
